# UniFi controller (UDM Pro)
UNIFI_API=https://192.168.1.1
UNIFI_USERNAME=tf-admin
UNIFI_PASSWORD=replace-me
UNIFI_SITE=default
UNIFI_INSECURE=true

# X-API-KEY for the read-only Integration v1 API
# Network → Settings → Control Plane → Integrations → API Key
UNIFI_API_KEY=

# Terraform working tree on disk (relative paths resolve from CWD)
UNIFI_MCP_TF_DIR=./terraform
TERRAFORM_BIN=terraform

# When true, tf_apply skips the confirm_token check. Default false.
UNIFI_MCP_AUTO_APPROVE=false
