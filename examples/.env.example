# MAGI quickstart environment template
# Copy to .env and adjust as needed.

# ---- Core configuration ----
MEMORY_BACKEND=sqlite
SQLITE_PATH=~/.magi/memory-local.db
POSTGRES_URL=
MYSQL_DSN=
SQLSERVER_URL=
SQLSERVER_HOST=
SQLSERVER_PORT=
SQLSERVER_DATABASE=
SQLSERVER_USER=
SQLSERVER_PASSWORD=
TURSO_URL=
TURSO_AUTH_TOKEN=
MAGI_REPLICA_PATH=~/.magi/memory.db
MAGI_SYNC_INTERVAL=60s
MAGI_API_TOKEN=your-token-here
MAGI_MACHINE_TOKENS_JSON=
MAGI_MACHINE_TOKENS_FILE=
MAGI_GRPC_PORT=8300
MAGI_HTTP_PORT=8301
MAGI_LEGACY_HTTP_PORT=8302
MAGI_UI_ENABLED=true
MAGI_UI_PORT=8080

# ---- Performance and pipeline tuning ----
MAGI_ASYNC_WRITES=false
MAGI_WRITE_WORKERS=
MAGI_WRITE_QUEUE_SIZE=1000
MAGI_BATCH_FLUSH_INTERVAL=100ms
MAGI_BATCH_MAX_SIZE=50
MAGI_CACHE_ENABLED=false
MAGI_CACHE_QUERY_TTL=60s
MAGI_CACHE_MEMORY_SIZE=1000
MAGI_CACHE_EMBEDDING_SIZE=5000
MAGI_EMBED_WORKERS=
MAGI_MODEL_DIR=~/.magi/models
ONNXRUNTIME_LIB=
MAGI_TURBOQUANT_ENABLED=
MAGI_TURBOQUANT_BITS=

# ---- Auth and secrets ----
MAGI_SECRET_MODE=reject
MAGI_SECRET_BACKEND=
MAGI_REDACTED=
MAGI_VAULT_TOKEN=
MAGI_VAULT_MOUNT=secret
MAGI_VAULT_NAMESPACE=
MAGI_TRUSTED_PROXY_AUTH=false

# ---- Git-backed history ----
MAGI_GIT_ENABLED=false
MAGI_GIT_PATH=
MAGI_GIT_COMMIT_MODE=immediate
MAGI_GIT_BATCH_INTERVAL=

# ---- Node mesh (optional) ----
MAGI_NODE_MODE=embedded
MAGI_WRITER_POOL_SIZE=4
MAGI_READER_POOL_SIZE=8
MAGI_COORDINATOR_ENABLED=true

# ---- Client convenience ----
MAGI_HTTP_URL=http://localhost:8302
MAGI_HTTP_TIMEOUT=10
