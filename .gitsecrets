# Secret patterns to detect before commit
# Vault tokens
hvs\.[A-Za-z0-9]{24,}
# Generic API keys/tokens (long base64-ish strings after key= or token=)
(api[_-]?key|secret|token|password)\s*[:=]\s*['"]?[A-Za-z0-9_\-/+=]{20,}
# IP addresses in the homelab range (prevent leaking internal topology)
10\.5\.\d+\.\d+
# Vault role IDs
[a-f0-9]{8}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{4}-[a-f0-9]{12}
# Bearer tokens
[Bb]earer\s+[A-Za-z0-9_\-/+=.]{20,}
